APP_NAME=3DGS Reconstruction Service
DEBUG=false
SECRET_KEY=change-me-in-production
MOCK_AUTH_ENABLED=false
MOCK_AUTH_USERNAME=mock_user
MOCK_AUTH_EMAIL=mock_user@example.com

DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/3dgs
DATABASE_URL_SYNC=postgresql://user:password@postgres:5432/3dgs
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
REDIS_URL=redis://redis:6379/2

STORAGE_BACKEND=s3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=3dgs-files
S3_REGION=us-east-1
API_SCRATCH_PATH=/tmp/3dgs-api
RECONSTRUCTION_SCRATCH_PATH=/scratch/reconstruction
DOWNLOAD_SESSION_TTL_SECONDS=86400
MEDIA_QUEUE_NAME=media
MEDIA_WORKER_CONCURRENCY=2
MEDIA_SCRATCH_PATH=/scratch/media
MEDIA_MAX_IMAGE_PIXELS=100000000
MEDIA_THUMBNAIL_MAX_EDGE=512
MEDIA_THUMBNAIL_JPEG_QUALITY=80
MEDIA_TASK_MAX_RETRIES=3
MEDIA_RETRY_COUNTDOWN_SECONDS=30
MEDIA_STALE_PROCESSING_SECONDS=300

MAX_FILE_SIZE=10737418240
UPLOAD_CHUNK_SIZE=5242880
DOWNLOAD_CHUNK_SIZE=5242880
DEFAULT_USER_STORAGE_QUOTA=53687091200
DEFAULT_USER_TASK_QUOTA=10
DEFAULT_USER_GPU_QUOTA=3600
DEFAULT_USER_ACTIVE_TASK_QUOTA=10
DEFAULT_USER_GPU_CONCURRENCY_QUOTA=1
DEFAULT_USER_GPU_DAILY_QUOTA_SECONDS=3600
GPU_QUOTA_TIMEZONE=Asia/Shanghai
TASK_TIMEOUT_SECONDS=7200
TASK_MAX_RETRIES=3

RECONSTRUCTION_POLL_INTERVAL_SECONDS=2
RECONSTRUCTION_QUEUE_NAME=reconstruction
RECONSTRUCTION_WORKER_CONCURRENCY=8
RECONSTRUCTION_PREFLIGHT_ON_START=true
RECONSTRUCTION_STALE_PROCESSING_SECONDS=300
RECONSTRUCTION_OUTPUT_PLY_GLOB=**/*.ply
DEFAULT_RECONSTRUCTION_ALGORITHM=anysplat
DEFAULT_MESH_ALGORITHM=dash_gaussian_mesh
WORKER_NODE_ID=gpu-node-01
WORKER_EXECUTOR_ID=gpu-worker-01
GPU_SCHEDULER_MODE=local
GPU_DEVICE_IDS=0,1,2,3,4,5,6,7
GPU_LEASE_TTL_SECONDS=60
GPU_RETRY_COUNTDOWN_SECONDS=10
GPU_MEMORY_BUSY_THRESHOLD_MB=512
GPU_REQUIRE_NVIDIA_SMI=true

ANYSPLAT_HOST_PATH=/data1/lzh/lzy/AnySplat
DASH_GAUSSIAN_HOST_PATH=/data1/lzh/lzy/DashGaussian
VGGT_OMEGA_HOST_PATH=/data1/lzh/lzy/vggt-omega
HUNYUAN3D_HOST_PATH=/data1/lzh/lzy/hunyuan3d-2.1
ANACONDA_HOST_PATH=/data1/lzh/anaconda3
HF_CACHE_HOST_PATH=/data1/lzh/.cache/huggingface
U2NET_HOST_PATH=/data1/lzh/.u2net

ANYSPLAT_PYTHON_PATH=/data1/lzh/anaconda3/envs/anysplat/bin/python
ANYSPLAT_PATH=/data1/lzh/lzy/AnySplat
ANYSPLAT_ENTRYPOINT=/data1/lzh/lzy/AnySplat/export_scene_gaussians.py
ANYSPLAT_ARGS_TEMPLATE={input_path} --frame_nums {frame_nums} --output_folder {output_folder} --crop_quantile {crop_quantile}
ANYSPLAT_TIMEOUT_SECONDS=600

DASH_GAUSSIAN_CONDA_PATH=/data1/lzh/anaconda3/bin/conda
DASH_GAUSSIAN_PATH=/data1/lzh/lzy/DashGaussian
DASH_GAUSSIAN_ENTRYPOINT=train_dash.py
DASH_GAUSSIAN_ARGS_TEMPLATE=--input_path {input_path} -m {output_folder} --iterations {iterations} --disable_viewer
DASH_GAUSSIAN_COMMAND_TEMPLATE={python_path} run -n DashGaussian python {entrypoint} {args}
DASH_GAUSSIAN_TIMEOUT_SECONDS=7200

VGGT_OMEGA_PYTHON_PATH=/opt/conda/bin/conda
VGGT_OMEGA_PATH=/algorithms/vggt-omega
VGGT_OMEGA_ENTRYPOINT=example.py
VGGT_OMEGA_ARGS_TEMPLATE=--input {input_path} --output_dir {output_folder}
VGGT_OMEGA_COMMAND_TEMPLATE={python_path} run -n anysplat python {entrypoint} {args}
VGGT_OMEGA_TIMEOUT_SECONDS=1200
VGGT_OMEGA_OUTPUT_GLOB=**/*
VGGT_OMEGA_RESULT_CATEGORY=other
VGGT_OMEGA_RESULT_MIME_TYPE=application/octet-stream
VGGT_OMEGA_RESULT_FILENAME=vggt_omega_result

HUNYUAN3D_CONDA_PATH=/data1/lzh/anaconda3/bin/conda
HUNYUAN3D_PATH=/data1/lzh/lzy/hunyuan3d-2.1
HUNYUAN3D_ENTRYPOINT=example.py
HUNYUAN3D_ARGS_TEMPLATE={input_path} -o {output_glb}
HUNYUAN3D_COMMAND_TEMPLATE={python_path} run -n hunyuan3d python {entrypoint} {args}
HUNYUAN3D_TIMEOUT_SECONDS=1800
